## 6. taxRates.js Structure

```js
// © 2026 TaxBackwards.ca. All rights reserved.
export const TAX_RATES = {
  ON: {
    name: "Ontario",
    type: "HST",
    rate: 0.13,
    fraction: "13/113",
    editorialSummary: "...",
    exemptionsNotice: "...",
    officialCraLink: "https://canada.ca/...",
    active: true
  },
  QC: {
    name: "Quebec",
    type: "GST+QST",
    rate: 0.14975,
    gst: 0.05,
    qst: 0.09975,
    fraction: "1/1.14975",
    editorialSummary: "...",
    exemptionsNotice: "...",
    officialCraLink: "https://revenuquebec.ca/...",
    active: true
  },
  BC: {
    name: "British Columbia",
    type: "GST+PST",
    rate: 0.12,
    gst: 0.05,
    pst: 0.07,
    fraction: "12/112",
    editorialSummary: "...",
    exemptionsNotice: "...",
    officialCraLink: "https://www2.gov.bc.ca/...",
    active: true
  }
  // All 13 provinces present; inactive provinces have active: false
};

export const PROVINCE_ORDER = ["ON", "QC", "NS", "NB", "PE", "NL", "BC", "AB", "SK", "MB", "YT", "NT", "NU"];
export const LAST_VERIFIED = "2026-05-15"; // Update on every rate verification
```

**Rules:**
- Every province object must contain: `name, type, rate, fraction, editorialSummary, exemptionsNotice, officialCraLink, active`
- Quebec (`GST+QST` type) must also have separate `gst` and `qst` fields
- GST+PST provinces (BC, SK, MB) must also have separate `gst` and `pst` fields — same pattern as GST+QST
- `LAST_VERIFIED` must be updated whenever any provincial data changes
- Never delete a province object — use `active: false` instead

